<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF7F7"
    android:padding="16dp"
    tools:context=".AddTimetableActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <EditText
            android:id="@+id/etCourseName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter Course Name (e.g., B.Sc. CompSci)"
            android:inputType="textCapWords" />

        <Button
            android:id="@+id/btnTimetableAddTeacher"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Add Teacher" />
        <TextView
            android:id="@+id/etTimetableTeachersAdded0"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Added : 0" />

        <Button
            android:id="@+id/btnTimetableAddSubject"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Add Subject" />
        <TextView
            android:id="@+id/etSubAdd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Added : 0" />

        <Button
            android:id="@+id/btnAddTimeSlot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Add Time Slot" />

        <Button
            android:id="@+id/btnAddDay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Select Working Days" />

        <Button
            android:id="@+id/btnAddRecess"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Select Recess Times" />
        
        <Button
            android:id="@+id/btnSetTeacherAvailability"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Set Teacher Availability" />

        <TextView
            style="@style/TextAppearance.AppCompat.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Constraints" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/toggleOverlap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Prevent same subject on same day" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/toggleClash"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Prevent teacher from having multiple classes in same slot (for multiple courses)" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/toggleWorkload"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Balance teacher workload evenly" />

        <Button
            android:id="@+id/btnGenerateTimetable"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="32dp"
            android:text="Generate Timetable" />

    </LinearLayout>
</ScrollView>