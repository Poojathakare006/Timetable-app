<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Left Accent Strip for Ongoing Lecture -->
        <View
            android:id="@+id/viewAccentStrip"
            android:layout_width="6dp"
            android:layout_height="match_parent"
            android:background="@color/brand_primary"
            android:visibility="gone" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- Time Slot - Top Right -->
            <TextView
                android:id="@+id/tvCardTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_alignParentTop="true"
                android:text="11:00 AM – 12:00 PM"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toStartOf="@id/tvCardTime"
                android:layout_alignParentStart="true"
                android:layout_marginEnd="8dp"
                android:orientation="vertical">

                <!-- Subject Name: 18sp semi-bold, capitalized -->
                <TextView
                    android:id="@+id/tvCardSubject"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SUBJECT NAME"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium"
                    android:textAllCaps="true"
                    android:textColor="@color/text_primary" />

                <!-- Faculty: 14sp medium, no brackets -->
                <TextView
                    android:id="@+id/tvCardTeacher"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Faculty Name"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- Status and Now Badge -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_below="@id/tvCardTime"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvNowBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_now_badge"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:text="NOW"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvCardStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="✅"
                    android:textSize="18sp" />

            </LinearLayout>

        </RelativeLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>