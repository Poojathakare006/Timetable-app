<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/ivPdfIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_pdf"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvHistoryCourseName"
            app:layout_constraintBottom_toBottomOf="@id/tvHistoryFileSize" />

        <TextView
            android:id="@+id/tvHistoryCourseName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="BCA 6th Sem"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/ivPdfIcon"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvHistoryDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Created on: 23-Jul-2024"
            app:layout_constraintStart_toStartOf="@id/tvHistoryCourseName"
            app:layout_constraintTop_toBottomOf="@id/tvHistoryCourseName" />

        <TextView
            android:id="@+id/tvHistoryFileSize"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Size: 24 KB"
            app:layout_constraintStart_toStartOf="@id/tvHistoryDate"
            app:layout_constraintTop_toBottomOf="@id/tvHistoryDate" />

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/content_barrier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="ivPdfIcon,tvHistoryFileSize" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeletePdf"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Delete"
            android:textColor="@android:color/holo_red_dark"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/content_barrier" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSharePdf"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Share"
            app:layout_constraintEnd_toStartOf="@id/btnDeletePdf"
            app:layout_constraintTop_toTopOf="@id/btnDeletePdf" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewPdf"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="View"
            app:layout_constraintEnd_toStartOf="@id/btnSharePdf"
            app:layout_constraintTop_toTopOf="@id/btnDeletePdf" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>