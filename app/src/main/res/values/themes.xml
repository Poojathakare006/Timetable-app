<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.TimetableApplication" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryDark">@color/brand_primary</item>
        <item name="colorAccent">@color/brand_accent</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item> <!-- Black icons -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <!-- Correct theme for HomeActivity -->
    <style name="Theme.HomeActivity" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryDark">@color/brand_primary</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item> <!-- Black icons -->
    </style>

</resources>