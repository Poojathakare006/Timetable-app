<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.TimetableApplication" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/dashboard_header</item>
        <item name="colorPrimaryDark">@color/dashboard_header</item>
        <item name="android:statusBarColor" tools:targetApi="l">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item> <!-- Use light icons on dark status bar -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <!-- Correct theme for HomeActivity -->
    <style name="Theme.HomeActivity" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/dashboard_header</item>
        <item name="colorPrimaryDark">@color/dashboard_header</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/dashboard_header</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item> <!-- Use light icons on dark status bar -->
    </style>

</resources>